{
  "name": "flavor-galaxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Interactive explorer for the Epicure food-ingredient embeddings (arXiv 2605.22391)",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prep": "node scripts/prep-data.mjs",
