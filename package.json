    "test": "node --test scripts/lib/normalize.test.mjs src/recipeIndex.test.mjs src/recipeIndex.error.test.mjs"
  },
  "dependencies": {
    "@deck.gl/core": "^9.3.4",
    "@deck.gl/layers": "^9.3.4"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "umap-js": "^1.4.0",
    "vite": "^6.3.5"
  }
}
